# Copy to .env and fill in. NEVER commit the populated file.

# --- Database (MySQL) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_DB=max_muscle_coaching
DB_DIALECT=mysql

# DB sync behavior (optional). One of:
#   DB_SYNC_FORCE=true   → drops and recreates tables (DEV ONLY)
#   DB_SYNC_ALTER=true   → ALTER existing tables to match models
DB_SYNC_FORCE=
DB_SYNC_ALTER=

# --- JWT ---
# Generate a 64+ byte random hex string. ROTATE on any suspected leak.
JWT_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=30d
JWT_MAIL_EXPIRATION=1h
JWT_RESERVATION_EXPIRATION=24h

# --- SMTP (account-confirmation + password-reset mail) ---
AUTH_USER_EMAIL=
AUTH_USER_PASSWORD=
HOST_MAIL=ssl0.ovh.net
MAIL_PORT=465

# --- App-level encryption (optional, for at-rest fields) ---
ENCRYPTION_METHOD=aes-256-cbc
ENCRYPTION_KEY=

# --- HTTP / CORS ---
# Comma-separated list of allowed origins for browser callers.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5050
# Hops between the public edge (e.g. Caddy) and Node — used by express-rate-limit.
TRUST_PROXY_HOPS=1

# --- Logging ---
LOG_LEVEL=info
